<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:property name="M_PI" value="3.14159"/> 
  <xacro:property name="laser_min_range" value="0.1"/>
  <xacro:property name="laser_max_range" value="200.0"/>
  <xacro:property name="ros_topic" value="points_mid"/>
  <xacro:property name="samples" value="24000"/>
  <xacro:property name="downsample" value="2"/>
  
  <xacro:macro name="null_inertial">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.01" ixy="0" ixz="0"
               iyy="0.01" iyz="0"
               izz="0.01"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="Livox_Mid_gazebo_sensor" params="visualize:=True update_rate:=10 resolution:=0.002 noise_mean:=0.0 noise_stddev:=0.01 name:=livox">
    <gazebo reference="${name}">
      <sensor type="ray" name="${name}">
        <pose>0 0 0 0 0 0</pose>
        <visualize>${visualize}</visualize>
        <update_rate>${update_rate}</update_rate>
        <plugin name="gazebo_ros_laser_controller" filename="liblivox_laser_simulation.so">
          <ray>
            <scan>
              <horizontal>
                <samples>100</samples>
                <resolution>1</resolution>
                <min_angle>${0}</min_angle>
                <max_angle>${2*M_PI}</max_angle>
              </horizontal>
              <vertical>
                <samples>360</samples>
                <resolution>1</resolution>
                <min_angle>${-7.22/180*M_PI}</min_angle>
                <max_angle>${55.22/180*M_PI}</max_angle>
              </vertical>
            </scan>
            <range>
              <min>${laser_min_range}</min>
              <max>${laser_max_range}</max>
              <resolution>${resolution}</resolution>
            </range>
            <noise>
              <type>gaussian</type>
              <mean>${noise_mean}</mean>
              <stddev>${noise_stddev}</stddev>
            </noise>
          </ray>
          <visualize>${visualize}</visualize>
          <samples>${samples}</samples>
          <downsample>${downsample}</downsample>
          <csv_file_name>package://livox_laser_simulation/scan_mode/mid360.csv</csv_file_name>
          <ros_topic>${ros_topic}</ros_topic>
        </plugin>
      </sensor>
    </gazebo>
  </xacro:macro>

  <!--
    Livox Mid-360 URDF 宏
    参数:
      name      - 雷达名称前缀 (默认 livox)
      parent    - 父 link (默认 base_link)
      xyz       - 安装位置偏移 (默认 "0.45 0 0.45")
      rpy       - 安装姿态 (默认 "0 0 0")
      visualize - 是否在 Gazebo 中可视化 (默认 true)

    结构: parent → laser_${name} (直接挂载，无中间 link)
  -->
  <xacro:macro name="Livox_Mid40" params="visualize:=True name:=livox parent:=base_link xyz:='0.45 0 0.45' rpy:='0 0 0'">
    <!-- 传感器 link (带 mesh visual) -->
    <link name="laser_${name}">
      <xacro:null_inertial/>
      <visual> 
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://livox_laser_simulation/meshes/livox_mid40.dae"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://livox_laser_simulation/meshes/livox_mid40.dae"/>
        </geometry>
      </collision>
    </link>

    <!-- 固定关节: 父 link → 传感器 (直接挂载) -->
    <joint name="${name}_mount_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="laser_${name}"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
    </joint>

    <!-- Gazebo 传感器插件 -->
    <xacro:Livox_Mid_gazebo_sensor name="laser_${name}" visualize="${visualize}"/>
  </xacro:macro>
</robot>