<?xml version="1.0"?>
<robot name="ackermann_car" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ================= 参数定义 ================= -->
  <xacro:property name="wheel_radius" value="0.1" />
  <xacro:property name="wheel_width" value="0.05" />
  <xacro:property name="wheel_base" value="0.35" /> <!-- 前后轴距 -->
  <xacro:property name="wheel_track" value="0.3" />  <!-- 左右轮距 -->
  <xacro:property name="base_mass" value="5.0" />

  <!-- 惯性矩阵宏：圆柱体 -->
  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(3*r*r+h*h)/12}" ixy="0" ixz="0" 
               iyy="${m*(3*r*r+h*h)/12}" iyz="0" 
               izz="${m*r*r/2}"/>
    </inertial>
  </xacro:macro>

  <!-- ================= 核心链路 ================= -->
  
  <!-- 0. 虚拟根节点 (消除KDL警告) -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- 1. 车身 -->
  <link name="base_link">
    <visual>
      <geometry><box size="0.5 0.2 0.1"/></geometry>
      <material name="blue"><color rgba="0 0 0.8 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.5 0.2 0.1"/></geometry>
    </collision>
    <inertial>
      <mass value="${base_mass}"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <!-- 2. 后轮宏 (驱动轮) -->
  <xacro:macro name="rear_wheel" params="name y_reflect">
    <link name="rear_${name}_wheel">
      <visual>
        <origin rpy="1.5708 0 0" xyz="0 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </visual>
      <collision>
        <origin rpy="1.5708 0 0" xyz="0 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <xacro:cylinder_inertia m="0.5" r="${wheel_radius}" h="${wheel_width}"/>
    </link>

    <joint name="rear_${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="rear_${name}_wheel"/>
      <origin xyz="-0.175 ${y_reflect * wheel_track/2} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>

    <gazebo reference="rear_${name}_wheel">
      <mu1>1.0</mu1>
      <mu2>1.0</mu2>
      <material>Gazebo/Black</material>
    </gazebo>
  </xacro:macro>

  <xacro:rear_wheel name="left" y_reflect="1"/>
  <xacro:rear_wheel name="right" y_reflect="-1"/>

  <!-- 3. 前轮宏 (转向轮) -->
  <xacro:macro name="front_wheel" params="name y_reflect">
    <!-- 转向节 -->
    <link name="front_${name}_steer">
      <inertial>
        <mass value="0.2"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
    </link>

    <joint name="front_${name}_steer_joint" type="revolute">
      <parent link="base_link"/>
      <child link="front_${name}_steer"/>
      <origin xyz="0.175 ${y_reflect * wheel_track/2} 0" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-0.6" upper="0.6" effort="50" velocity="5.0"/>
    </joint>

    <!-- 轮子本体 -->
    <link name="front_${name}_wheel">
      <visual>
        <origin rpy="1.5708 0 0" xyz="0 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </visual>
      <collision>
        <origin rpy="1.5708 0 0" xyz="0 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <xacro:cylinder_inertia m="0.5" r="${wheel_radius}" h="${wheel_width}"/>
    </link>

    <joint name="front_${name}_wheel_joint" type="continuous">
      <parent link="front_${name}_steer"/>
      <child link="front_${name}_wheel"/>
      <axis xyz="0 1 0"/>
    </joint>

    <gazebo reference="front_${name}_wheel">
      <mu1>1.0</mu1>
      <mu2>1.0</mu2>
      <material>Gazebo/Black</material>
    </gazebo>
  </xacro:macro>

  <xacro:front_wheel name="left" y_reflect="1"/>
  <xacro:front_wheel name="right" y_reflect="-1"/>

  <!-- ================= 驱动插件 (Tricycle Drive) ================= -->
  <!-- 
    该插件在Gazebo中模拟转向+驱动。虽然叫Tricycle，但可以通过配置Joints适配四轮阿克曼结构。
  -->
  <gazebo>
    <plugin name="tricycle_drive" filename="libgazebo_ros_tricycle_drive.so">
      <rosDebugLevel>Debug</rosDebugLevel>
      <robotNamespace>/</robotNamespace>
      <publishWheelTF>false</publishWheelTF>
      <publishWheelJointState>true</publishWheelJointState>
      
      <!-- 控制参数 -->
      <steeringJoint>front_left_steer_joint</steeringJoint>
      <actuatedWheelJoint>rear_left_wheel_joint</actuatedWheelJoint>
      
      <wheelSeparation>${wheel_track}</wheelSeparation>
      <wheelDiameter>${2*wheel_radius}</wheelDiameter>
      
      <wheelAcceleration>2.0</wheelAcceleration>
      <wheelTorque>50.0</wheelTorque>
      
      <commandTopic>cmd_vel</commandTopic>
      <odometryTopic>odom</odometryTopic>
      <odometryFrame>odom</odometryFrame>
      <robotBaseFrame>base_footprint</robotBaseFrame>
    </plugin>
  </gazebo>

</robot>