<!-- =================================================================================== -->
<robot name="my_robot">
  <!-- <xacro:include filename="$(find livox_laser_simulation)/urdf/livox_mid360.xacro"/> -->
  <!-- 颜色宏 -->
  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>
  <link name="base_footprint"/>
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.1"/>
  </joint>
  <!-- 1. 底盘 -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="1.0 0.4 0.1"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="1.0 0.4 0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin rpy="-1.57 0 0" xyz="-0.2 0.225 -0.05"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin rpy="-1.57 0 0" xyz="-0.2 -0.225 -0.05"/>
    <axis xyz="0 0 1"/>
  </joint>
  <!-- 添加支撑脚 (万向轮) -->
  <link name="caster_wheel">
    <visual>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>
  <!-- 支撑脚关节 (固定连接) -->
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin rpy="0 0 0" xyz="0.4 0 -0.1"/>
  </joint>
  <!-- 给万向轮设置摩擦力 (Gazebo 专用) -->
  <gazebo reference="caster_wheel">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>
  <!-- 激光雷达 Link -->
  <link name="laser_link">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.03"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.05" radius="0.03"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>
  <!-- 激光雷达 Joint -->
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <!-- 放在底盘上方 (base_z + 0.05/2) -->
    <origin rpy="0 0 0" xyz="0 0 0.075"/>
  </joint>
  <link name="velodyne_base_link">
    <inertial>
      <mass value="0.83"/>
      <inertia ixx="0.000908" ixy="0" ixz="0" iyy="0.000908" iyz="0" izz="0.001104"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder length="0.0717" radius="0.0516"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>
  <joint name="velodyne_base_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="velodyne_base_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.5"/>
  </joint>
  <!-- 显式传入参数 -->
  <VLP-16 gpu="true" hz="10" name="velodyne" parent="base_link" samples="440" topic="/velodyne_points">
    <origin rpy="0 0 0" xyz="0 0 0.5"/>
  </VLP-16>
  <!-- <xacro:Livox_Mid40 name="livox"/>
  <xacro:include filename="$(find livox_laser_simulation)/urdf/standardrobots_oasis300.xacro"/>
  <xacro:link_oasis name="oasis"/> -->
  <link name="livox_base">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0.00 0 0.0"/>
      <geometry>
        <mesh filename="package://livox_laser_simulation/meshes/livox_mid40.dae">
          </mesh>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://livox_laser_simulation/meshes/livox_mid40.dae"> 
		  </mesh>
      </geometry>
    </collision>
  </link>
  <link name="livox">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>
  <joint name="livox_to_livox_base_joint" type="fixed">
    <parent link="livox_base"/>
    <child link="livox"/>
    <origin rpy="0 0 0" xyz="0.0 1.0 0.2"/>
  </joint>
  <gazebo reference="livox">
    <sensor name="laser_livox" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <visualize>False</visualize>
      <update_rate>10</update_rate>
      <!-- This ray plgin is only for visualization. -->
      <plugin filename="liblivox_laser_simulation.so" name="gazebo_ros_laser_controller">
        <ray>
          <scan>
            <horizontal>
              <samples>100</samples>
              <resolution>1</resolution>
              <min_angle>0</min_angle>
              <max_angle>6.28318</max_angle>
            </horizontal>
            <vertical>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-0.12601266555555554</min_angle>
              <max_angle>0.9637699988888888</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.1</min>
            <max>200.0</max>
            <resolution>0.002</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
        </ray>
        <visualize>False</visualize>
        <samples>24000</samples>
        <downsample>10</downsample>
        <csv_file_name>package://livox_laser_simulation/scan_mode/mid360.csv</csv_file_name>
        <ros_topic>points_mid</ros_topic>
      </plugin>
    </sensor>
  </gazebo>
  <!-- 3. 手动创建一个关节，把雷达绑在小车上 -->
  <!-- 注意：Livox 生成的基座 link 名字通常是 "你的name参数_base"，也就是 "livox_base" -->
  <joint name="livox_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="livox_base"/>
    <origin rpy="0 0 0" xyz="0.45 0.0 0.45"/>
  </joint>
  <!-- 3. Gazebo 差速驱动插件 -->
  <gazebo>
    <plugin filename="libgazebo_ros_diff_drive.so" name="differential_drive_controller">
      <legacyMode>false</legacyMode>
      <rosDebugLevel>na</rosDebugLevel>
      <alwaysOn>true</alwaysOn>
      <updateRate>20</updateRate>
      <leftJoint>left_wheel_joint</leftJoint>
      <rightJoint>right_wheel_joint</rightJoint>
      <wheelSeparation>0.45</wheelSeparation>
      <wheelDiameter>0.2</wheelDiameter>
      <torque>20</torque>
      <commandTopic>cmd_vel</commandTopic>
      <odometryTopic>odom</odometryTopic>
      <odometryFrame>odom</odometryFrame>
      <robotBaseFrame>base_link</robotBaseFrame>
      <!-- 补充这些参数 -->
      <publishWheelTF>true</publishWheelTF>
      <publishOdomTF>true</publishOdomTF>
      <publishWheelJointState>true</publishWheelJointState>
      <wheelAcceleration>1.0</wheelAcceleration>
      <wheelTorque>20</wheelTorque>
      <odometrySource>world</odometrySource>
      <publishTf>1</publishTf>
    </plugin>
  </gazebo>
  <gazebo reference="laser_link">
    <sensor name="head_hokuyo_sensor" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <visualize>false</visualize>
      <update_rate>40</update_rate>
      <!-- 更新频率，越高越平滑，但越占CPU -->
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <!-- 扫描点数，720通常对应0.5度分辨率 -->
            <resolution>1</resolution>
            <min_angle>-3.1415926</min_angle>
            <max_angle>3.1415926</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.10</min>
          <!-- 盲区：小于此距离视为无效 -->
          <max>10.0</max>
          <!-- 测量上限 -->
          <resolution>0.01</resolution>
          <!-- 测距精度 -->
        </range>
        <!-- 添加噪声模型，仿真环境下的必备，否则SLAM效果太理想 -->
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
          <!-- 标准差，模拟0.01米的测量波动 -->
        </noise>
      </ray>
      <plugin filename="libgazebo_ros_laser.so" name="gazebo_ros_head_hokuyo_controller">
        <topicName>/scan</topicName>
        <frameName>laser_link</frameName>
        <rosDebugLevel>na</rosDebugLevel>
      </plugin>
    </sensor>
  </gazebo>
  <!-- 确保 Gazebo 传感器配置正确挂载到 velodyne_base_link -->
  <gazebo reference="velodyne_base_link">
    <sensor name="velodyne-VLP16" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <visualize>false</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>440</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>16</samples>
            <min_angle>-0.261799</min_angle>
            <max_angle>0.261799</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.3</min>
          <max>130.0</max>
          <resolution>0.001</resolution>
        </range>
      </ray>
      <plugin filename="libgazebo_ros_velodyne_laser.so" name="gazebo_ros_velodyne_laser_controller">
        <topicName>/velodyne_points</topicName>
        <frameName>velodyne_base_link</frameName>
        <min_range>0.9</min_range>
        <max_range>130.0</max_range>
        <gaussianNoise>0.008</gaussianNoise>
      </plugin>
    </sensor>
  </gazebo>
</robot>

