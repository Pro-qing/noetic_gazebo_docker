<?xml version="1.0"?>
<robot name="my_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- <xacro:include filename="$(find livox_laser_simulation)/urdf/livox_mid360.xacro"/> -->

  <!-- 参数定义 -->
  <xacro:property name="base_width" value="0.4"/>
  <xacro:property name="base_length" value="1.0"/>
  <xacro:property name="wheel_radius" value="0.1"/>
  <xacro:property name="wheel_width" value="0.05"/>

  <!-- 颜色宏 -->
  <material name="blue"> <color rgba="0 0 0.8 1"/> </material>
  <material name="black"> <color rgba="0 0 0 1"/> </material>

  <!-- 惯性矩阵宏 (Gazebo仿真必备，否则模型会乱飞) -->
  <xacro:macro name="default_inertial" params="mass">
    <inertial>
      <mass value="${mass}"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </xacro:macro>

  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/> 
  </joint>

  <!-- 1. 底盘 -->
  <link name="base_link">
    <visual>
      <geometry> <box size="${base_length} ${base_width} 0.1"/> </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry> <box size="${base_length} ${base_width} 0.1"/> </geometry>
    </collision>
    <xacro:default_inertial mass="5.0"/>
  </link>

  <!-- 2. 轮子宏 -->
  <xacro:macro name="wheel" params="prefix reflect">
    <link name="${prefix}_wheel">
      <visual>
        <geometry> <cylinder radius="${wheel_radius}" length="${wheel_width}"/> </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <geometry> <cylinder radius="${wheel_radius}" length="${wheel_width}"/> </geometry>
      </collision>
      <xacro:default_inertial mass="1.0"/>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel"/>
      <origin xyz="-0.2 ${reflect * (base_width/2 + wheel_width/2)} -0.05" rpy="-1.57 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>
  </xacro:macro>

  <!-- 调用轮子宏 -->
  <xacro:wheel prefix="left" reflect="1"/>
  <xacro:wheel prefix="right" reflect="-1"/>

    <!-- 添加支撑脚 (万向轮) -->
  <link name="caster_wheel">
    <visual>
      <geometry> <sphere radius="0.05"/> </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry> <sphere radius="0.05"/> </geometry>
    </collision>
    <xacro:default_inertial mass="0.5"/>
  </link>

  <!-- 支撑脚关节 (固定连接) -->
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="0.4 0 -0.1" rpy="0 0 0"/>
  </joint>

  <!-- 给万向轮设置摩擦力 (Gazebo 专用) -->
  <gazebo reference="caster_wheel">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

    <!-- 激光雷达 Link -->
  <link name="laser_link">
    <visual>
      <geometry> <cylinder radius="0.03" length="0.05"/> </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry> <cylinder radius="0.03" length="0.05"/> </geometry>
    </collision>
    <xacro:default_inertial mass="0.1"/>
  </link>

  <!-- 激光雷达 Joint -->
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <!-- 放在底盘上方 (base_z + 0.05/2) -->
    <origin xyz="0 0 0.075" rpy="0 0 0"/> 
  </joint>

  <link name="velodyne_base_link">
    <inertial>
      <mass value="0.83"/>
      <inertia ixx="0.000908" ixy="0" ixz="0" iyy="0.000908" iyz="0" izz="0.001104"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder length="0.0717" radius="0.0516"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="velodyne_base_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="velodyne_base_link"/>
    <origin xyz="0 0 0.5" rpy="0 0 0"/>
  </joint>

  <!-- 显式传入参数 -->
  <VLP-16 parent="base_link" name="velodyne" topic="/velodyne_points" hz="10" samples="440" gpu="true">
    <origin xyz="0 0 0.5" rpy="0 0 0" />
  </VLP-16>

  <!-- 1. 引入 Livox Mid-360 的宏定义文件 -->
  <xacro:include filename="$(find livox_laser_simulation)/urdf/livox_mid360.xacro"/>

  <!-- 2. 调用宏生成雷达 -->
  <xacro:Livox_Mid40 name="livox"/>

  <!-- 3. 手动创建一个关节，把雷达绑在小车上 -->
  <joint name="laser_livox_bridge_joint" type="fixed">
    <parent link="base_link"/>
    <child link="livox_base"/>
    <origin xyz="0.45 0.0 0.45" rpy="0 0 0" />
  </joint>

  <!-- 3. Gazebo 差速驱动插件 -->
  <gazebo>
    <plugin name="differential_drive_controller" filename="libgazebo_ros_diff_drive.so">
      <legacyMode>false</legacyMode>
      <rosDebugLevel>na</rosDebugLevel> 
      <alwaysOn>true</alwaysOn>
      <updateRate>20</updateRate>
      <leftJoint>left_wheel_joint</leftJoint>
      <rightJoint>right_wheel_joint</rightJoint>
      <wheelSeparation>${base_width + wheel_width}</wheelSeparation>
      <wheelDiameter>${2 * wheel_radius}</wheelDiameter>
      <torque>20</torque>
      <commandTopic>cmd_vel</commandTopic>
      <odometryTopic>odom</odometryTopic>
      <odometryFrame>odom</odometryFrame>
      <robotBaseFrame>base_link</robotBaseFrame>
      <!-- 补充这些参数 -->
      <publishWheelTF>true</publishWheelTF>
      <publishOdomTF>true</publishOdomTF>
      <publishWheelJointState>true</publishWheelJointState>
      <wheelAcceleration>1.0</wheelAcceleration>
      <wheelTorque>20</wheelTorque>
      <odometrySource>world</odometrySource>
      <publishTf>1</publishTf>
    </plugin>
  </gazebo>

  <gazebo reference="laser_link">
    <sensor type="ray" name="head_hokuyo_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>false</visualize>
      <update_rate>40</update_rate> <!-- 更新频率，越高越平滑，但越占CPU -->
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>      <!-- 扫描点数，720通常对应0.5度分辨率 -->
            <resolution>1</resolution>
            <min_angle>-3.1415926</min_angle>
            <max_angle>3.1415926</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.10</min>               <!-- 盲区：小于此距离视为无效 -->
          <max>10.0</max>               <!-- 测量上限 -->
          <resolution>0.01</resolution> <!-- 测距精度 -->
        </range>
        <!-- 添加噪声模型，仿真环境下的必备，否则SLAM效果太理想 -->
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>         <!-- 标准差，模拟0.01米的测量波动 -->
        </noise>
      </ray>
      <plugin name="gazebo_ros_head_hokuyo_controller" filename="libgazebo_ros_laser.so">
        <topicName>/scan</topicName>
        <frameName>laser_link</frameName>
        <rosDebugLevel>na</rosDebugLevel>
      </plugin>
    </sensor>
  </gazebo>

  <!-- 确保 Gazebo 传感器配置正确挂载到 velodyne_base_link -->
  <gazebo reference="velodyne_base_link">
    <sensor type="ray" name="velodyne-VLP16">
      <pose>0 0 0 0 0 0</pose>
      <visualize>false</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>440</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>16</samples>
            <min_angle>-0.261799</min_angle>
            <max_angle>0.261799</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.3</min>
          <max>130.0</max>
          <resolution>0.001</resolution>
        </range>
      </ray>
      <plugin name="gazebo_ros_velodyne_laser_controller" filename="libgazebo_ros_velodyne_laser.so">
        <topicName>/velodyne_points</topicName>
        <frameName>velodyne_base_link</frameName>
        <min_range>0.9</min_range>
        <max_range>130.0</max_range>
        <gaussianNoise>0.008</gaussianNoise>
      </plugin>
    </sensor>
  </gazebo>

</robot>